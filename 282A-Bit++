#include <bits/stdc++.h>
using namespace std;
int main() {
      int n,x=0,i;
      string b;
      cin >> n;
      for(i=0; i<n; i++)
      {
            cin >> b;
            if(b=="X++" || b=="++X")
            {
                  x++;
            }
            else{
                  x--;
            }
      }
      cout << x << endl;
}
